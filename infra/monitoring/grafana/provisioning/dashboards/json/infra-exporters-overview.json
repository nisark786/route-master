{
  "id": null,
  "uid": "infra-exporters-overview",
  "title": "Infrastructure Exporters Overview",
  "tags": ["infra", "redis", "rabbitmq", "postgres", "mongodb"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Redis Used Memory (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ Queued Messages",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rabbitmq_queue_messages)",
          "legendFormat": "queued",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Postgres Up",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "pg_up",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MongoDB Up",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "mongodb_up",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ]
}
