{
  "id": null,
  "uid": "sre-sla-reliability",
  "title": "SRE SLA and Reliability",
  "tags": ["sre", "sla", "slo", "production"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Core Availability % (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(django_http_responses_total_by_status_total[5m])), 1e-6)))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "AI Availability % (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(http_requests_total{job=\"ai_service\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"ai_service\"}[5m])), 1e-6)))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Core P95 Latency",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_including_middlewares_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "AI P95 Latency",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ai_service\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Core 5xx Error Ratio (5m)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(django_http_responses_total_by_status_total[5m])), 1e-6)",
          "legendFormat": "core",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "AI 5xx Error Ratio (5m)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"ai_service\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"ai_service\"}[5m])), 1e-6)",
          "legendFormat": "ai",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ Backlog",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "sum(rabbitmq_queue_messages)",
          "legendFormat": "queued messages",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Used Memory",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Postgres Active Connections",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends)",
          "legendFormat": "total backends",
          "refId": "A"
        }
      ]
    }
  ]
}
