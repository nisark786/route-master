{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowLambdaImageOptimizerManagement",
      "Effect": "Allow",
      "Action": [
        "lambda:AddPermission",
        "lambda:CreateFunction",
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:ListFunctions",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration"
      ],
      "Resource": [
        "arn:aws:lambda:ap-south-1:725224325392:function:route-management-image-optimizer"
      ]
    },
    {
      "Sid": "AllowCreateLambdaImageOptimizer",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:ListFunctions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowImageOptimizerRoleManagement",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:GetRole",
        "iam:PassRole",
        "iam:PutRolePolicy",
        "iam:UpdateAssumeRolePolicy"
      ],
      "Resource": [
        "arn:aws:iam::725224325392:role/route-management-image-optimizer-role"
      ]
    },
    {
      "Sid": "AllowBucketNotificationManagement",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:GetBucketNotification",
        "s3:PutBucketNotification"
      ],
      "Resource": "arn:aws:s3:::nisar-route-master-123"
    }
  ]
}
